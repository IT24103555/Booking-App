# Server
PORT=5000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Admin registration key
# If set, /api/auth/register can create an admin ONLY when request body includes:
# { "role": "admin", "adminKey": "<this value>" }
# If not set, admin registration is disabled.
ADMIN_REGISTER_KEY=replace_with_admin_register_key

# CORS
# For demo you can use * (not recommended for production)
CORS_ORIGIN=*
